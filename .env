# ─── Lighter.xyz Connection ───────────────────────────────────────────────────
BASE_URL=https://mainnet.zklighter.elliot.ai
# For testnet use: https://testnet.zklighter.elliot.ai

# ─── Your Wallet & Account ────────────────────────────────────────────────────
L1_ADDRESS=0xB0BeCEEAE37eAFaB017E8DB23AE2D8413884dcbD
ACCOUNT_INDEX=717235                   # Get from app.lighter.xyz or accountsByL1Address API

# ─── API Key (generated from lighter.xyz UI) ──────────────────────────────────
API_KEY_INDEX=3                      # 3-254; 0=desktop, 1=mobile PWA, 2=mobile app
API_PRIVATE_KEY=4392f262128656a339055af97fe3ab2082375c88f497261eab8ef292b41c928e3a7c92dc4d9ec716
# public key: 13c7c97211627eceb2740aa32605461370a31b89b5d070d2fb2e8131f8eba86f7e133d79fb4653c7
# ─── Market ───────────────────────────────────────────────────────────────────
# Run `python main.py --list-markets` to find XRP market_index
XRP_MARKET_INDEX=5                   # Update after querying markets

# ─── Risk Management ──────────────────────────────────────────────────────────
MAX_POSITION_SIZE=500                # Max XRP units to hold (long or short)
MAX_DAILY_LOSS_USDC=50              # Kill switch: stop trading if daily loss > this
MAX_ORDER_SIZE_XRP=100              # Max single order size in XRP base units
RISK_PER_TRADE_PCT=0.01             # 1% of collateral risked per trade

# ─── Strategy ─────────────────────────────────────────────────────────────────
# STRATEGY options: trend_following, mean_reversion, combined
STRATEGY=combined
POLL_INTERVAL_SECONDS=15            # How often to re-evaluate signals

# Trend Following (EMA Crossover + RSI filter)
EMA_FAST=9
EMA_SLOW=21
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30
ATR_PERIOD=14
ATR_SL_MULTIPLIER=1.5              # Stop-loss = ATR * multiplier
ATR_TP_MULTIPLIER=2.5              # Take-profit = ATR * multiplier

# Mean Reversion (Bollinger Bands)
BB_PERIOD=20
BB_STD_DEV=2.0
BB_MIN_SQUEEZE=0.005               # Minimum band width to avoid flat markets

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log

STRATEGY=super_combined
CANDLE_INTERVAL_SECONDS=300   # 5-min candles (recommended for XRP)
UT_ATR_PERIOD=10
UT_KEY_VALUE=1.5
UT_EMA_FILTER=200